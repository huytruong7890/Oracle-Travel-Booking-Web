@model webtour.Models.Booking

@{
    ViewData["Title"] = "Xác Nhận Xóa";
}

<div class="vt-section" style="padding-bottom:80px">
    <div class="vt-container" style="max-width:560px">
        <div class="vt-breadcrumb">
            <a asp-controller="Home" asp-action="Index">🏠 Trang chủ</a>
            <span class="sep">›</span>
            <a asp-action="Index">Danh Sách</a>
            <span class="sep">›</span>
            <span class="current">Xóa #@Model.Id</span>
        </div>
        <div class="vt-details-card" style="text-align:center;padding:48px 36px">
            <div style="font-size:56px;margin-bottom:16px">🗑️</div>
            <h1 style="font-size:22px;font-weight:800;color:#f87171;margin-bottom:8px">Xác Nhận Xóa</h1>
            <p style="color:var(--text-muted);margin-bottom:32px">
                Bạn có chắc muốn xóa đặt tour này khỏi Oracle Database? Thao tác này không thể hoàn tác.
            </p>

            <div style="background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.2);border-radius:12px;padding:20px;margin-bottom:32px;text-align:left">
                <div class="vt-detail-row">
                    <div class="vt-detail-key">Khách hàng</div>
                    <div class="vt-detail-val" style="font-weight:700">@Model.CustomerName</div>
                </div>
                <div class="vt-detail-row">
                    <div class="vt-detail-key">Email</div>
                    <div class="vt-detail-val">@Model.CustomerEmail</div>
                </div>
                <div class="vt-detail-row">
                    <div class="vt-detail-key">Tour</div>
                    <div class="vt-detail-val" style="color:var(--cyan)">@(Model.Tour?.Destination ?? "–")</div>
                </div>
                <div class="vt-detail-row">
                    <div class="vt-detail-key">Tổng tiền</div>
                    <div class="vt-detail-val" style="color:var(--green-light);font-weight:700">@Model.TotalPrice.ToString("N0")đ</div>
                </div>
            </div>

            <form asp-action="Delete" method="post" style="display:flex;gap:12px;justify-content:center">
                <button type="submit" class="vt-btn vt-btn-danger" style="flex:1;max-width:220px">🗑️ Xóa Khỏi Oracle</button>
                <a asp-action="Index" class="vt-btn vt-btn-outline" style="flex:1;max-width:180px">← Quay Lại</a>
            </form>
        </div>
    </div>
</div>
